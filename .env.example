# Database — SQLite by default (file is local, gitignored)
DATABASE_URL="file:./dev.db"

# Stripe — TEST MODE ONLY. Do not put live keys here.
# Get test keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""

# Stripe webhook signing secret — from `stripe listen --print-secret` or the dashboard
STRIPE_WEBHOOK_SECRET=""

# Cart session — used to sign anonymous cart cookies. Generate with `openssl rand -base64 32`.
CART_SESSION_SECRET="generate-with-openssl-rand-base64-32"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Sentry (optional) — leave blank and the SDK becomes a no-op
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
